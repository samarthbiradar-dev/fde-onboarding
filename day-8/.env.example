# Copy to .env for LOCAL runs only. On Railway, set these in the dashboard
# (Service → Variables) — never commit real secrets.

# ── STT + TTS (ElevenLabs) ──────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── LLM (Groq) ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key

# ── Plivo (enables auto hang-up) ────────────────────────────────────
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token

# ── Database ────────────────────────────────────────────────────────
# Local:   postgresql://localhost/calllog_db
# Railway: use the Postgres plugin's DATABASE_URL (reference variable)
DATABASE_URL=postgresql://localhost/calllog_db

# ── Public URL ──────────────────────────────────────────────────────
# Leave UNSET on Railway — auto-derived from RAILWAY_PUBLIC_DOMAIN.
# Set it only for local tunnel testing, e.g.:
# SERVER_URL=https://your-tunnel.trycloudflare.com
